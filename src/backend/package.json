{
  "name": "estate-kit-backend",
  "version": "1.0.0",
  "description": "Backend services for Estate Kit - a comprehensive estate planning and management system",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "test": "jest",
    "migrate": "ts-node scripts/db-migrate.ts",
    "seed": "ts-node scripts/db-seed.ts",
    "lint": "eslint . --ext .ts",
    "docs": "node scripts/generate-api-docs.ts"
  },
  "dependencies": {
    "auth0": "^2.37.0",
    "aws-sdk": "2.1360.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.10.0",
    "sequelize": "6.31.0",
    "swagger-ui": "4.15.5",
    "winston": "3.8.2",
    "yargs": "^17.7.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/auth0": "^2.34.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^18.15.0",
    "@types/pg": "^8.6.6",
    "@types/swagger-ui": "^3.52.0",
    "@types/yargs": "^17.0.24",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "eslint": "^8.35.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estate-kit/backend.git"
