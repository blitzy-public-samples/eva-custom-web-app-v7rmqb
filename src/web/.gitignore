# Node dependencies
# Addresses Version Control Hygiene requirement from Technical Specifications/4.5 Development & Deployment/Development Tools
node_modules/

# Build outputs
# Generated by vite build command
dist/
build/

# Environment files
# Sensitive configuration files that should never be committed
.env
.env.local
.env.*.local

# Test coverage reports
# Generated by Jest test runner
coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files
.DS_Store

# Log files
*.log

# Cache files
*.cache

# Lock files
# Package manager lock files should be committed in the root, not here
*.lock

# Temporary files
*.tmp

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak

# TypeScript build info
*.tsbuildinfo

# ESLint cache
.eslintcache

# Vite build cache
.vite/

# Temporary build files
.temp/
.tmp/

# Local development certificates
*.pem
*.key
*.crt

# Test artifacts
__snapshots__/
*.snap

# Storybook build output
storybook-static/

# Bundle analyzer reports
stats.html
bundle-analysis.html

# Miscellaneous
.env.development.local
.env.test.local
.env.production.local