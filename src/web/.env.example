# API Configuration
# Addresses Environment Configuration requirement from Technical Specifications/2.7 Cross-Cutting Concerns/Monitoring & Observability
REACT_APP_API_BASE_URL=https://api.estatekit.com

# Authentication Configuration (Auth0)
# Required for user authentication and authorization
REACT_APP_AUTH0_DOMAIN=your-auth0-domain.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-auth0-client-id

# Customer Support Integration (Intercom)
# Required for customer support functionality
REACT_APP_INTERCOM_APP_ID=your-intercom-app-id

# E-commerce Integration (Shopify)
# Required for payment processing and subscription management
REACT_APP_SHOPIFY_API_KEY=your-shopify-api-key

# Email Service Configuration (SendGrid)
# Required for email notifications and communications
REACT_APP_SENDGRID_API_KEY=your-sendgrid-api-key

# AWS Configuration
# Required for file storage and cloud services
REACT_APP_AWS_REGION=us-east-1
REACT_APP_AWS_S3_BUCKET=your-s3-bucket-name

# Cache Configuration (Redis)
# Required for application caching
REACT_APP_REDIS_URL=redis://localhost:6379

# Database Configuration
# Required for local development and testing
REACT_APP_DB_HOST=localhost
REACT_APP_DB_PORT=5432
REACT_APP_DB_USER=your-db-user
REACT_APP_DB_PASSWORD=your-db-password
REACT_APP_DB_NAME=estatekit

# Note: This is an example configuration file. In production:
# 1. Use secure, randomly generated values for all credentials
# 2. Enable encryption for sensitive configuration values
# 3. Ensure all API keys have appropriate access restrictions
# 4. Configure proper CORS and security headers
# 5. Use environment-specific configuration management